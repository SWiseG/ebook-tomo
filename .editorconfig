root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{json,yml,yaml,html,scss,ts,js}]
indent_size = 2

[*.cs]
csharp_style_namespace_declarations = file_scoped:warning
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_prefer_braces = true:warning
dotnet_sort_system_directives_first = true
dotnet_diagnostic.CA1848.severity = none  # LoggerMessage delegates: desnecessário no nosso volume
dotnet_diagnostic.CA2007.severity = none  # ConfigureAwait: app, não lib
dotnet_diagnostic.CA1031.severity = none  # catch geral permitido em workers/dispatchers
