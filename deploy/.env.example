# Copiar para /opt/ebook/.env no VPS (chmod 600). Nunca commitar o .env real.
# Convenção .NET: Seção:Chave  ->  Secao__Chave (duplo underscore).
ASPNETCORE_ENVIRONMENT=Production

# Imagem publicada no GHCR (usada pelo docker-compose): seu usuário/org do GitHub
GHCR_OWNER=seu-usuario-github

# ── Auth do painel (OBRIGATÓRIO) ─────────────────────────────────────────────
# Segredo:  openssl rand -base64 48
Jwt__Secret=TROCAR-POR-SEGREDO-ALEATORIO
AdminAuth__Username=admin
# Hash:  docker compose run --rm api dotnet Ebook.Api.dll hash-password 'SUA_SENHA'
AdminAuth__PasswordHash=pbkdf2.210000.xxx.yyy

# ── URL pública (LP/Meta usam para links absolutos) ──────────────────────────
# Configure também lp.baseUrl no painel (Configurações) com este mesmo valor.
Meta__PublicMediaBaseUrl=https://app.SEU-DOMINIO

# IA — assinatura Claude Pro via CLI (sessão persistida no volume /opt/ebook/claude)
Ai__DefaultMonthlyCallCap=1500
# ANTHROPIC_API_KEY=            # vazio = fallback API pago desligado (padrão)

# ── Integrações (preencher quando ligar cada gate) ───────────────────────────
Pexels__ApiKey=

# Kiwify (E07): a senha NÃO vai aqui — a sessão é criada via 'kiwify-login'.
Kiwify__Email=
Kiwify__WebhookToken=
Kiwify__Headless=true

# Meta / Instagram-Facebook (E08/E10)
Meta__PageId=
Meta__IgUserId=
Meta__AccessToken=

# Vídeo (E10): caminhos dos binários dentro do container
Video__FfmpegPath=ffmpeg
Video__PiperPath=
Video__PiperVoicePath=

# ── Backup Litestream → Cloudflare R2 (opcional) ─────────────────────────────
R2_ENDPOINT=https://SEU-ACCOUNT-ID.r2.cloudflarestorage.com
R2_BUCKET=ebook-backup
R2_ACCESS_KEY=
R2_SECRET=
