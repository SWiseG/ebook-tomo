{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Quartz": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "./data/logs/ebook-.json",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Data": {
    "RootPath": "./data"
  },
  "Ai": {
    "PromptsPath": "./prompts",
    "ClaudeCommand": "claude",
    "ClaudeTimeoutSeconds": 300,
    "DefaultMonthlyCallCap": 1500
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "ebook",
    "Audience": "ebook-admin",
    "LifetimeMinutes": 480
  },
  "AdminAuth": {
    "Username": "",
    "PasswordHash": ""
  },
  "Scheduling": {
    "HousekeepingCron": "0 0 3 * * ?"
  },
  "AllowedHosts": "*"
}
