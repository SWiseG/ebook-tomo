{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Quartz": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "./data/logs/ebook-.json",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Data": {
    "RootPath": "./data"
  },
  "Ai": {
    "PromptsPath": "./prompts",
    "ClaudeCommand": "claude",
    "ClaudeTimeoutSeconds": 300,
    "DefaultMonthlyCallCap": 1500
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "ebook",
    "Audience": "ebook-admin",
    "LifetimeMinutes": 480
  },
  "AdminAuth": {
    "Username": "",
    "PasswordHash": ""
  },
  "Scheduling": {
    "HousekeepingCron": "0 0 3 * * ?"
  },
  "Kiwify": {
    "BaseUrl": "https://dashboard.kiwify.com.br",
    "Email": "",
    "WebhookToken": "",
    "StorageStatePath": "/data/kiwify/storage-state.json",
    "Headless": true,
    "ClientId": "",
    "ClientSecret": "",
    "AccountId": "",
    "PublicApiBaseUrl": "https://public-api.kiwify.com",
    "CheckoutBaseUrl": "https://pay.kiwify.com.br"
  },
  "Meta": {
    "GraphApiVersion": "v21.0",
    "ApiBase": "https://graph.facebook.com",
    "PageId": "",
    "IgUserId": "",
    "AccessToken": "",
    "PublicMediaBaseUrl": ""
  },
  "Video": {
    "PiperPath": "",
    "PiperVoicePath": "",
    "FfmpegPath": "ffmpeg",
    "TimeoutSeconds": 300
  },
  "Media": {
    "Gemini": { "Enabled": true, "ApiKey": "", "Model": "imagen-3.0-generate-002", "DailyLimit": 100 },
    "Cloudflare": { "Enabled": true, "ApiKey": "", "AccountId": "", "Model": "@cf/black-forest-labs/flux-1-schnell", "DailyLimit": 200 },
    "HuggingFace": { "Enabled": true, "ApiKey": "", "Model": "black-forest-labs/FLUX.1-schnell", "DailyLimit": 0 },
    "Pollinations": { "Enabled": true, "Model": "flux" }
  },
  "AllowedHosts": "*"
}
